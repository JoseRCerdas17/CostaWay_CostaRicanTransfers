# Local Development
# DATABASE_URL=postgresql://user:password@localhost:5432/costaway

# Railway Deployment (DATABASE_URL is auto-set when PostgreSQL plugin is connected)
# Just leave DATABASE_URL unset or empty - Railway will provide it

JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=CostaWay <noreply@costaway.com>
ADMIN_EMAIL=admin@costaway.com

# For local dev: ["http://localhost:3000"]
# For production: add your Vercel domain
CORS_ORIGINS=["http://localhost:3000", "https://*.vercel.app"]

API_V1_PREFIX=/api/v1
